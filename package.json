  "bugs": {
    "url": "https://github.com/uci-ml-repo/ucimlrepo-feedback",
    "email": "ucirepository@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uci-ml-repo/website-next"
