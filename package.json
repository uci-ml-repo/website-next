  "type": "module",
  "scripts": {
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "docker compose down && docker compose up -d --build",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbopack",
    "email:dev": "dotenv -e .env -- email dev --dir ./src/server/service/email/templates",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint --fix",
    "tscheck": "tsc --noEmit --incremental false --excludeDirectories '.next'",
    "prepare": "husky",
    "start": "dotenv -e .env -- next start",
    "server": "pm2-runtime start ecosystem.config.cjs"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  },
