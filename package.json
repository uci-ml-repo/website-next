  "type": "module",
  "scripts": {
    "build": "next build",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "docker compose down && docker compose up -d && sleep 1 && drizzle-kit push",
    "db:seed": "tsx ./src/db/seed/index.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbopack",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint --fix",
    "prepare": "husky",
    "start": "dotenv -e .env -- next start"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  },
