datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String @id @default(cuid())
  email String @unique @db.VarChar(255)

  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  image         String?
  name          String

  role UserRole  @default(BASIC)
  data UserData?

  accounts Account[]
  sessions Session[]
  datasets Dataset[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserData {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  bookmarkedDatasets DatasetBookmark[]

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("user_data")
}

model DatasetBookmark {
  userDataId String @map("user_data_id")
  datasetId  Int    @map("dataset_id")

  bookmarkedAt DateTime @default(now()) @map("bookmarked_at")

  userData UserData @relation(fields: [userDataId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  dataset  Dataset  @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([userDataId, datasetId])
  @@index([bookmarkedAt])
  @@map("dataset_bookmarks")
}

model Dataset {
  id                Int                @id @default(autoincrement())
  status            ApprovalStatus     @default(PENDING)
  donatedAt         DateTime           @default(now()) @map("donated_at") @db.Date
  yearCreated       Int                @map("year_created")
  title             String             @db.VarChar(255)
  description       String             @db.Text
  subjectArea       DatasetSubjectArea @map("subject_area")
  isTabular         Boolean            @map("is_tabular")
  hasMissingValues  Boolean            @map("has_missing_values")
  instanceCount     Int                @map("instance_count")
  featureCount      Int                @map("feature_count")
  hasGraphics       Boolean            @default(false) @map("has_graphics")
  isAvailablePython Boolean            @default(false) @map("is_available_python")
  viewCount         Int                @default(0) @map("view_count")
  downloadCount     Int                @default(0) @map("download_count")
  slug              String             @unique @db.VarChar(255)

  characteristics DatasetCharacteristic[]
  tasks           DatasetTask[]
  featureTypes    FeatureType[]           @map("feature_types")
  authors         DatasetAuthor[]
  keywords        DatasetKeyword[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  files   DatasetFile[]
  zipFile DatasetFile?  @relation("ZipFile")

  citedIn           DatasetPaper[]
  introductoryPaper DatasetPaper?  @relation("IntroductoryPaper")

  subtitle     String? @db.VarChar(255)
  doi          String? @db.VarChar(255)
  externalLink String? @db.VarChar(255)

  bookmarks DatasetBookmark[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, slug])
  @@map("datasets")
}

model DraftDataset {
  id String @id @default(cuid())

  // TODO add fields

  @@map("draft_datasets")
}

model DatasetAuthor {
  id          String  @id @default(cuid())
  datasetId   Int     @map("dataset_id")
  firstName   String  @db.VarChar(255)
  lastName    String  @db.VarChar(255)
  institution String? @db.VarChar(255)
  email       String? @db.VarChar(255)

  dataset Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_authors")
}

model DatasetFile {
  id        String @id @default(cuid())
  path      String
  sizeBytes Int    @map("size_bytes")

  datasetId       Int?     @map("dataset_id")
  dataset         Dataset? @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  zipForDatasetId Int?     @unique
  zipForDataset   Dataset? @relation("ZipFile", fields: [zipForDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@index([sizeBytes])
  @@map("dataset_files")
}

model DatasetPaper {
  id String @id @default(cuid())

  title   String   @db.VarChar(255)
  authors String[] @db.VarChar(255)
  venue   String   @db.VarChar(255)
  year    Int
  url     String   @db.VarChar(255)

  datasetId                Int?     @map("dataset_id")
  dataset                  Dataset? @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  introductoryForDatasetId Int?     @unique
  introductoryForDataset   Dataset? @relation("IntroductoryPaper", fields: [introductoryForDatasetId], references: [id], onUpdate: Restrict, onDelete: Cascade)

  @@map("dataset_papers")
}

model Keyword {
  id     String         @id @default(cuid())
  name   String         @db.VarChar(255)
  status ApprovalStatus @default(PENDING)

  datasets DatasetKeyword[]

  @@map("keywords")
}

model DatasetKeyword {
  datasetId Int    @map("dataset_id")
  keywordId String @map("keyword_id")

  dataset Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([datasetId, keywordId])
  @@map("dataset_keywords")
}

enum UserRole {
  ADMIN     @map("admin")
  LIBRARIAN @map("librarian")
  CURATOR   @map("curator")
  BASIC     @map("basic")

  @@map("user_role")
}

enum ApprovalStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")

  @@map("approval_status")
}

enum DatasetSubjectArea {
  BIOLOGY                 @map("biology")
  BUSINESS                @map("business")
  CLIMATE_AND_ENVIRONMENT @map("climate_and_environment")
  COMPUTER_SCIENCE        @map("computer_science")
  EDUCATION               @map("education")
  ENGINEERING             @map("engineering")
  GAMES                   @map("games")
  HEALTH_AND_MEDICINE     @map("health_and_medicine")
  LAW                     @map("law")
  PHYSICS_AND_CHEMISTRY   @map("physics_and_chemistry")
  SOCIAL_SCIENCE          @map("social_science")
  OTHER                   @map("other")

  @@map("dataset_area")
}

enum DatasetTask {
  CLASSIFICATION @map("classification")
  REGRESSION     @map("regression")
  CLUSTERING     @map("clustering")

  @@map("dataset_task")
}

enum DatasetCharacteristic {
  TABULAR        @map("tabular")
  SEQUENTIAL     @map("sequential")
  MULTIVARIATE   @map("multivariate")
  TIME_SERIES    @map("time_series")
  TEXT           @map("text")
  IMAGE          @map("image")
  SPATIOTEMPORAL @map("spatiotemporal")

  @@map("dataset_characteristic")
}

enum FeatureType {
  CATEGORICAL @map("categorical")
  INTEGER     @map("integer")
  REAL        @map("real")

  @@map("feature_type")
}

// ============================================================================
// Auth
// ============================================================================
model Account {
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  createdAt DateTime @default(now()) @map("created_at")

  @@id([identifier, token])
  @@map("verification_tokens")
}
