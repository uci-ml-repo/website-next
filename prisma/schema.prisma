datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// Users
// ============================================================================
model User {
  id    String @id @default(cuid())
  email String @unique @db.VarChar(255)

  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  image         String?
  name          String

  role UserRole @default(BASIC)

  accounts      Account[]
  sessions      Session[]
  datasets      Dataset[]
  draftDatasets DraftDataset[]

  bookmarks           Bookmark[]
  discussionPosts     Discussion[]       @relation("DiscussionPost")
  discussionDeletions Discussion[]       @relation("DiscussionDeletion")
  discussionUpvotes   DiscussionUpvote[]

  datasetReports              DatasetReport[]
  datasetReportResolutions    DatasetReportResolution[]
  discussionReports           DiscussionReport[]
  discussionReportResolutions DiscussionReportResolution[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================================================
// User Data
// ============================================================================
model Bookmark {
  userId    String @map("user_id")
  datasetId Int    @map("dataset_id")

  bookmarkedAt DateTime @default(now()) @map("bookmarked_at")

  user    User    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  dataset Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([userId, datasetId])
  @@map("bookmarks")
}

// ============================================================================
// Datasets
// ============================================================================
model Dataset {
  id                Int                @id @default(autoincrement())
  status            ApprovalStatus     @default(PENDING)
  donatedAt         DateTime           @default(now()) @map("donated_at") @db.Date
  yearCreated       Int                @map("year_created")
  title             String             @db.VarChar(255)
  description       String             @db.Text
  subjectArea       DatasetSubjectArea @map("subject_area")
  instanceCount     Int                @map("instance_count")
  hasGraphics       Boolean            @default(false) @map("has_graphics")
  isAvailablePython Boolean            @default(false) @map("is_available_python")
  viewCount         Int                @default(0) @map("view_count")
  downloadCount     Int                @default(0) @map("download_count")
  slug              String             @unique @db.VarChar(255)

  featureCount Int?    @map("feature_count")
  subtitle     String? @db.VarChar(255)
  doi          String? @db.VarChar(255)
  externalLink String? @map("external_link") @db.VarChar(255)

  variablesDescription String?            @map("variables_description") @db.Text
  variables            DatasetVariables[]

  characteristics DatasetCharacteristic[]
  tasks           DatasetTask[]
  featureTypes    DatasetFeatureType[]    @map("feature_types")
  authors         DatasetAuthor[]
  keywords        DatasetKeyword[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  citedIn           DatasetPaper[]
  introductoryPaper DatasetPaper?  @relation("IntroductoryPaper")

  searchVector String? @db.TsVector

  bookmarks   Bookmark[]
  discussions Discussion[]
  reports     DatasetReport[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("datasets")
}

model DraftDataset {
  id    String @id @default(cuid())
  title String @db.VarChar(255)

  yearCreated   Int?                @map("year_created")
  description   String?             @db.Text
  subjectArea   DatasetSubjectArea? @map("subject_area")
  instanceCount Int?                @map("instance_count")
  hasGraphics   Boolean?            @default(false) @map("has_graphics")
  featureCount  Int?                @map("feature_count")
  subtitle      String?             @db.VarChar(255)
  doi           String?             @db.VarChar(255)
  externalLink  String?             @map("external_link") @db.VarChar(255)

  variablesDescription String?            @map("variables_description") @db.Text
  variables            DatasetVariables[]

  characteristics DatasetCharacteristic[]
  tasks           DatasetTask[]
  featureTypes    DatasetFeatureType[]    @map("feature_types")
  authors         DatasetAuthor[]
  keywords        DatasetKeyword[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  introductoryPaper DatasetPaper?

  fileCount Int? @map("file_count")
  zipSize   Int? @map("zip_size")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("draft_datasets")
}

model DatasetVariables {
  id            String             @id @default(cuid())
  name          String             @db.VarChar(255)
  role          DatasetFeatureRole
  type          DatasetFeatureType
  description   String?            @db.Text
  units         String?            @db.VarChar(255)
  missingValues Boolean

  datasetId Int?     @map("dataset_id")
  dataset   Dataset? @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  draftDatasetId String?       @map("draft_dataset_id")
  draftDataset   DraftDataset? @relation(fields: [draftDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_variables")
}

model DatasetAuthor {
  id          String  @id @default(cuid())
  firstName   String  @db.VarChar(255)
  lastName    String  @db.VarChar(255)
  institution String? @db.VarChar(255)
  email       String? @db.VarChar(255)

  datasetId Int     @map("dataset_id")
  dataset   Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  draftDatasetId String?       @map("draft_dataset_id")
  draftDataset   DraftDataset? @relation(fields: [draftDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_authors")
}

model DatasetPaper {
  id String @id @default(cuid())

  title   String   @db.VarChar(255)
  authors String[] @db.VarChar(255)
  venue   String   @db.VarChar(255)
  year    Int

  semanticScholarId Int @map("semantic_scholar_id") // Corpus ID, see https://api.semanticscholar.org/api-docs

  datasetId                Int?     @map("dataset_id")
  dataset                  Dataset? @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  introductoryForDatasetId Int?     @unique @map("introductory_for_dataset_id")
  introductoryForDataset   Dataset? @relation("IntroductoryPaper", fields: [introductoryForDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  draftDatasetId String?       @unique @map("draft_dataset_id")
  draftDataset   DraftDataset? @relation(fields: [draftDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_papers")
}

model Keyword {
  id     String         @id @default(cuid())
  name   String         @db.VarChar(255)
  status ApprovalStatus @default(PENDING)

  datasets DatasetKeyword[]

  @@map("keywords")
}

model DatasetKeyword {
  id String @id @default(cuid())

  keywordId String  @map("keyword_id")
  keyword   Keyword @relation(fields: [keywordId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  datasetId Int?     @map("dataset_id")
  dataset   Dataset? @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  draftDatasetId String?       @map("draft_dataset_id")
  draftDataset   DraftDataset? @relation(fields: [draftDatasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_keywords")
}

// ============================================================================
// Discussions
// ============================================================================
model Discussion {
  id String @id @default(cuid())

  content String @db.Text

  replyToId String?      @map("reply_to_id")
  replyTo   Discussion?  @relation("Replies", fields: [replyToId], references: [id], onDelete: Cascade)
  replies   Discussion[] @relation("Replies")

  userId String @map("user_id")
  user   User   @relation("DiscussionPost", fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  datasetId Int     @map("dataset_id")
  dataset   Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  upvoteCount Int                @default(0) @map("upvote_count")
  upvotes     DiscussionUpvote[]

  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")

  deletedByUserId String?                 @map("deleted_by_user_id")
  deletedBy       User?                   @relation("DiscussionDeletion", fields: [deletedByUserId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  deletedAt       DateTime?               @map("deleted_at")
  deletionReason  DiscussionReportReason? @map("deletion_reason")

  reports DiscussionReport[]

  @@index([createdAt])
  @@map("discussions")
}

model DiscussionUpvote {
  userId       String   @map("user_id")
  discussionId String   @map("discussion_id")
  upvotedAt    DateTime @default(now()) @map("upvoted_at")

  user       User       @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([userId, discussionId])
  @@map("discussion_upvotes")
}

// ============================================================================
// Reports
// ============================================================================
model DatasetReport {
  id String @id @default(cuid())

  reason  DatasetReportReason
  details String              @db.Text

  reportedAt DateTime @default(now()) @map("reported_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  resolution DatasetReportResolution?

  datasetId Int     @map("dataset_id")
  dataset   Dataset @relation(fields: [datasetId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_reports")
}

model DatasetReportResolution {
  id String @id @default(cuid())

  type    ReportResolutionType
  comment String?              @db.Text

  resolvedAt DateTime @default(now()) @map("resolved_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  reportId String        @unique @map("report_id")
  report   DatasetReport @relation(fields: [reportId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("dataset_report_resolutions")
}

model DiscussionReport {
  id String @id @default(cuid())

  reason  DiscussionReportReason
  details String?                @db.Text

  reportedAt DateTime @default(now()) @map("reported_at")

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  resolution DiscussionReportResolution?

  discussionId String     @map("discussion_id")
  discussion   Discussion @relation(fields: [discussionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("discussion_reports")
}

model DiscussionReportResolution {
  id String @id @default(cuid())

  type    ReportResolutionType
  comment String?              @db.Text

  resolvedAt DateTime @default(now()) @map("resolved_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  reportId String           @unique @map("report_id")
  report   DiscussionReport @relation(fields: [reportId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("discussion_report_resolutions")
}

// ============================================================================
// Auth
// ============================================================================
model Account {
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  createdAt DateTime @default(now()) @map("created_at")

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// Enums
// ============================================================================
enum UserRole {
  ADMIN     @map("admin")
  LIBRARIAN @map("librarian")
  CURATOR   @map("curator")
  BASIC     @map("basic")

  @@map("user_role")
}

enum ApprovalStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")

  @@map("approval_status")
}

enum DatasetSubjectArea {
  BIOLOGY                 @map("biology")
  BUSINESS                @map("business")
  CLIMATE_AND_ENVIRONMENT @map("climate_and_environment")
  COMPUTER_SCIENCE        @map("computer_science")
  EDUCATION               @map("education")
  ENGINEERING             @map("engineering")
  GAMES                   @map("games")
  HEALTH_AND_MEDICINE     @map("health_and_medicine")
  LAW                     @map("law")
  PHYSICS_AND_CHEMISTRY   @map("physics_and_chemistry")
  SOCIAL_SCIENCE          @map("social_science")
  OTHER                   @map("other")

  @@map("dataset_subject_area")
}

enum DatasetTask {
  CLASSIFICATION @map("classification")
  REGRESSION     @map("regression")
  CLUSTERING     @map("clustering")

  @@map("dataset_task")
}

enum DatasetCharacteristic {
  TABULAR        @map("tabular")
  SEQUENTIAL     @map("sequential")
  MULTIVARIATE   @map("multivariate")
  TIME_SERIES    @map("time_series")
  TEXT           @map("text")
  IMAGE          @map("image")
  SPATIOTEMPORAL @map("spatiotemporal")

  @@map("dataset_characteristic")
}

enum DatasetFeatureRole {
  ID      @map("id")
  FEATURE @map("feature")
  TARGET  @map("target")
  OTHER   @map("other")

  @@map("dataset_feature_role")
}

enum DatasetFeatureType {
  CATEGORICAL @map("categorical")
  INTEGER     @map("integer")
  CONTINUOUS  @map("continuous")
  BINARY      @map("binary")
  TEXT        @map("text")
  DATE        @map("date")
  OTHER       @map("other")

  @@map("dataset_feature_type")
}

enum DatasetReportReason {
  MISSING_FILES_OR_DATA @map("missing_files_or_data")
  INACCURATE_METADATA   @map("inaccurate_metadata")
  OTHER                 @map("other")

  @@map("dataset_report_reason")
}

enum DiscussionReportReason {
  SPAM           @map("spam")
  UNPROFESSIONAL @map("unprofessional")
  INAPPROPRIATE  @map("inappropriate")
  OTHER          @map("other")

  @@map("discussion_report_reason")
}

enum ReportResolutionType {
  IGNORED  @map("ignored")
  RESOLVED @map("resolved")

  @@map("dataset_report_resolution_type")
}
